{
  "manifest_version": 3,
  "name": "A Tracker",
  "version": "1.0.0",
  "description": "追踪纽约金、纽约银、纽约铜、纽约原油及 A 股实时价格",
  "permissions": [
    "storage",
    "alarms",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://hq.sinajs.cn/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "A Tracker"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "commands": {
    "toggle-badge": {
      "suggested_key": {
        "default": "Ctrl+K",
        "mac": "Command+K"
      },
      "description": "展示/隐藏角标"
    }
  }
}
